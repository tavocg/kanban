#!/usr/bin/env python3
"""Terminal Kanban board renderer.

Directory layout:
KANBAN_HOME/
  <board>/
    <tab>/
      <card>.md
"""

from __future__ import annotations

import argparse
import hashlib
import math
import os
import re
import shutil
import sys
import textwrap
import unicodedata
from dataclasses import dataclass, replace
from datetime import datetime, timedelta
from pathlib import Path
from typing import Iterable

ANSI_RE = re.compile(r"\x1b\[[0-9;]*m")
DEFAULT_MAX_CONTENT = 180
AGENDA_WINDOW_DAYS = 15
COLOR_CODES = [
    33,
    39,
    45,
    51,
    69,
    75,
    81,
    99,
    117,
    129,
    141,
    165,
    178,
    197,
    203,
    208,
]


@dataclass
class Card:
    title: str
    tags: list[str]
    content: str
    path: Path
    done: bool = False
    archive: bool = False
    due: datetime | None = None
    due_text: str | None = None


class AmbiguousBoardMatchError(ValueError):
    def __init__(self, board_name: str, matches: list[str]) -> None:
        self.board_name = board_name
        self.matches = matches
        rendered = ", ".join(matches)
        super().__init__(f"Board '{board_name}' is ambiguous. Matches: {rendered}")


def default_kanban_home() -> Path:
    env = os.environ.get("KANBAN_HOME")
    if env:
        return Path(env).expanduser()
    return Path.home() / "Documents" / "boards"


def strip_quotes(value: str) -> str:
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in {"'", '"'}:
        return value[1:-1]
    return value


def split_frontmatter(raw: str) -> tuple[str, str]:
    if not raw.startswith("---"):
        return "", raw

    lines = raw.splitlines(keepends=True)
    if not lines or lines[0].strip() != "---":
        return "", raw

    for i in range(1, len(lines)):
        if lines[i].strip() == "---":
            frontmatter = "".join(lines[1:i])
            body = "".join(lines[i + 1 :])
            return frontmatter, body

    return "", raw


def parse_frontmatter(block: str) -> dict[str, object]:
    meta: dict[str, object] = {}
    lines = block.splitlines()
    i = 0

    while i < len(lines):
        line = lines[i].rstrip()
        stripped = line.strip()

        if not stripped or stripped.startswith("#"):
            i += 1
            continue

        if ":" not in line:
            i += 1
            continue

        key, value = line.split(":", 1)
        key = key.strip()
        value = value.strip()

        if key == "tags" and not value:
            tags: list[str] = []
            i += 1
            while i < len(lines):
                candidate = lines[i].strip()
                if candidate.startswith("- "):
                    tag = strip_quotes(candidate[2:].strip())
                    if tag:
                        tags.append(tag)
                    i += 1
                else:
                    break
            meta[key] = tags
            continue

        meta[key] = strip_quotes(value)
        i += 1

    return meta


def parse_tags(raw: object) -> list[str]:
    if raw is None:
        return []

    parts: list[str]
    if isinstance(raw, list):
        parts = [str(item) for item in raw]
    elif isinstance(raw, str):
        text = raw.strip()
        if text.startswith("[") and text.endswith("]"):
            inner = text[1:-1].strip()
            parts = [] if not inner else [chunk.strip() for chunk in inner.split(",")]
        elif "," in text:
            parts = [chunk.strip() for chunk in text.split(",")]
        elif text:
            parts = [text]
        else:
            parts = []
    else:
        parts = [str(raw)]

    seen: set[str] = set()
    normalized: list[str] = []
    for part in parts:
        tag = strip_quotes(part).strip()
        if tag and tag not in seen:
            seen.add(tag)
            normalized.append(tag)

    return normalized


def parse_bool(raw: object) -> bool:
    if isinstance(raw, bool):
        return raw
    if raw is None:
        return False
    if isinstance(raw, (int, float)):
        return bool(raw)

    text = str(raw).strip().lower()
    return text in {"1", "true", "yes", "y", "on"}


def parse_due(raw: object) -> datetime | None:
    if raw is None:
        return None

    value = strip_quotes(str(raw).strip())
    if not value:
        return None

    if value.endswith("Z"):
        value = f"{value[:-1]}+00:00"

    try:
        return datetime.fromisoformat(value)
    except ValueError:
        return None


def parse_card(path: Path) -> Card:
    raw = path.read_text(encoding="utf-8")
    frontmatter, body = split_frontmatter(raw)

    title = path.stem
    tags: list[str] = []
    done = False
    archive = False
    due: datetime | None = None
    due_text: str | None = None

    if frontmatter:
        meta = parse_frontmatter(frontmatter)
        title_value = meta.get("title")
        if isinstance(title_value, str) and title_value.strip():
            title = title_value.strip()
        tags = parse_tags(meta.get("tags"))
        done = parse_bool(meta.get("done"))
        archive = parse_bool(meta.get("archive"))
        due_raw = meta.get("due")
        if due_raw is not None:
            due_text = strip_quotes(str(due_raw).strip()) or None
        due = parse_due(due_raw)

    return Card(
        title=title,
        tags=tags,
        content=body.strip(),
        path=path,
        done=done,
        archive=archive,
        due=due,
        due_text=due_text,
    )


def truncate_content(text: str, max_length: int) -> str:
    if max_length < 0 or len(text) <= max_length:
        return text
    if max_length <= 3:
        return "." * max_length
    return text[: max_length - 3].rstrip() + "..."


def hash_color(tag: str) -> int:
    digest = hashlib.sha256(tag.encode("utf-8")).digest()
    return COLOR_CODES[digest[0] % len(COLOR_CODES)]


def visible_len(text: str) -> int:
    return len(ANSI_RE.sub("", text))


def pad_visible(text: str, width: int) -> str:
    current = visible_len(text)
    if current >= width:
        return text
    return text + (" " * (width - current))


def wrap_plain_text(text: str, width: int) -> list[str]:
    if width <= 1:
        return [text]

    out: list[str] = []
    paragraphs = text.splitlines() or [text]

    for paragraph in paragraphs:
        if not paragraph.strip():
            out.append("")
            continue
        out.extend(
            textwrap.wrap(
                paragraph,
                width=width,
                break_long_words=True,
                break_on_hyphens=False,
            )
        )

    return out or [""]


class Renderer:
    def __init__(self, enable_color: bool) -> None:
        self.enable_color = enable_color

    def bold(self, text: str) -> str:
        if not self.enable_color:
            return text
        return f"\033[1m{text}\033[0m"

    def color_tag(self, tag: str) -> str:
        label = f"[{tag}]"
        if not self.enable_color:
            return label
        code = hash_color(tag)
        return f"\033[38;5;{code}m{label}\033[0m"

    def muted(self, text: str) -> str:
        if not self.enable_color or not text:
            return text
        return f"\033[90m{text}\033[0m"

    def strikethrough(self, text: str) -> str:
        if not self.enable_color or not text:
            return text
        return f"\033[9m{text}\033[0m"

    def strikethrough_preserving_styles(self, text: str) -> str:
        if not self.enable_color or not text:
            return text
        # Re-apply strikethrough after resets embedded in styled text.
        reapplied = text.replace("\033[0m", "\033[0m\033[9m")
        return f"\033[9m{reapplied}\033[0m"


def list_boards(home: Path) -> list[str]:
    if not home.exists() or not home.is_dir():
        return []
    return sorted(
        [item.name for item in home.iterdir() if item.is_dir()], key=str.lower
    )


def normalize_board_name(value: str) -> str:
    normalized = unicodedata.normalize("NFKD", value.strip().casefold())
    without_marks = "".join(
        char for char in normalized if not unicodedata.combining(char)
    )
    return " ".join(without_marks.split())


def board_match_score(query: str, candidate: str) -> tuple[int, int, int, int] | None:
    if not query or not candidate:
        return None
    if query == candidate:
        return (0, 0, 0, len(candidate))

    index = candidate.find(query)
    if index == -1:
        return None

    prefix_penalty = 0 if index == 0 else 1
    remainder = len(candidate) - len(query)
    return (1, prefix_penalty, index, remainder)


def resolve_board_name(home: Path, board_name: str) -> str:
    boards = list_boards(home)
    if board_name in boards:
        return board_name

    normalized_query = normalize_board_name(board_name)
    scored_matches: list[tuple[tuple[int, int, int, int], str]] = []

    for candidate in boards:
        score = board_match_score(
            normalized_query, normalize_board_name(candidate)
        )
        if score is not None:
            scored_matches.append((score, candidate))

    if not scored_matches:
        raise FileNotFoundError(f"Board '{board_name}' not found in {home}")

    scored_matches.sort(key=lambda item: (item[0], normalize_board_name(item[1])))
    best_score = scored_matches[0][0]
    best_matches = [match for score, match in scored_matches if score == best_score]
    if len(best_matches) > 1:
        raise AmbiguousBoardMatchError(board_name, best_matches)

    return scored_matches[0][1]


def load_board(home: Path, board_name: str) -> tuple[Path, dict[str, list[Card]]]:
    board_dir = home / board_name
    if not board_dir.exists() or not board_dir.is_dir():
        raise FileNotFoundError(f"Board '{board_name}' not found in {home}")

    tabs = sorted(
        [item for item in board_dir.iterdir() if item.is_dir()],
        key=lambda p: p.name.lower(),
    )
    board_data: dict[str, list[Card]] = {}

    for tab_dir in tabs:
        cards = [
            parse_card(path)
            for path in sorted(tab_dir.glob("*.md"), key=lambda p: p.name.lower())
        ]
        board_data[tab_dir.name] = cards

    return board_dir, board_data


def chunked(items: list[str], size: int) -> Iterable[list[str]]:
    for i in range(0, len(items), size):
        yield items[i : i + size]


def localize_due(
    due: datetime, now: datetime | None = None
) -> tuple[datetime, datetime]:
    current = now or datetime.now().astimezone()
    if due.tzinfo is None:
        return current, due.replace(tzinfo=current.tzinfo)
    return current, due.astimezone(current.tzinfo)


def format_due_line(due: datetime, due_text: str | None = None) -> str:
    now, target = localize_due(due)
    seconds = (target - now).total_seconds()
    if seconds <= 0:
        return f"Due {due_text}" if due_text else "Due now"
    if seconds >= 24 * 60 * 60:
        return f"Due in {math.ceil(seconds / (24 * 60 * 60))}d"
    if seconds >= 60 * 60:
        return f"Due in {math.ceil(seconds / (60 * 60))}h"
    if seconds > 0:
        return f"Due in {math.ceil(seconds / 60)}m"
    return "Due now"


def format_tags_line(
    tags: list[str], width: int, renderer: Renderer, colorize: bool = True
) -> list[str]:
    if not tags:
        return []

    lines: list[list[str]] = []
    current: list[str] = []
    current_len = 0

    for tag in tags:
        plain = f"[{tag}]"
        add_len = len(plain) if current_len == 0 else len(plain) + 1

        if current and current_len + add_len > width:
            lines.append(current)
            current = [tag]
            current_len = len(plain)
        else:
            current.append(tag)
            current_len += add_len

    if current:
        lines.append(current)

    if colorize:
        return [" ".join(renderer.color_tag(tag) for tag in line) for line in lines]
    return [" ".join(f"[{tag}]" for tag in line) for line in lines]


def build_card_lines(
    card: Card, width: int, max_content: int, renderer: Renderer
) -> list[str]:
    lines: list[str] = []

    title = card.title.strip() or card.path.stem
    due_label = (
        format_due_line(card.due, card.due_text) if card.due is not None else None
    )
    bullet = " • "
    header = title if due_label is None else f"{title}{bullet}{due_label}"
    for line in wrap_plain_text(header, width):
        lines.append(renderer.bold(line))

    lines.extend(format_tags_line(card.tags, width, renderer, colorize=True))

    content = truncate_content(card.content, max_content)
    if content:
        content_lines = wrap_plain_text(content, width)
        for line in content_lines:
            lines.append(renderer.muted(line))

    lines.append("")
    if card.done:
        return [
            renderer.strikethrough_preserving_styles(line) if line else line
            for line in lines
        ]
    return lines


def build_due_agenda(home: Path) -> dict[str, list[Card]]:
    now = datetime.now().astimezone()
    cutoff = now + timedelta(days=AGENDA_WINDOW_DAYS)
    agenda: dict[str, list[Card]] = {"Overdue": [], "Next 7 days": []}

    for board_name in list_boards(home):
        _, board_data = load_board(home, board_name)
        for cards in board_data.values():
            for card in cards:
                if card.archive or card.due is None:
                    continue

                _, target = localize_due(card.due, now)
                agenda_card = replace(
                    card,
                    title=f"{board_name} • {card.title.strip() or card.path.stem}",
                )

                if target <= now:
                    if card.done:
                        continue
                    agenda["Overdue"].append(agenda_card)
                elif target <= cutoff:
                    agenda["Next 7 days"].append(agenda_card)

    def due_sort_key(card: Card) -> tuple[float, str]:
        if card.due is None:
            return (float("inf"), card.title.lower())
        _, target = localize_due(card.due, now)
        return (target.timestamp(), card.title.lower())

    for tab_name in agenda:
        agenda[tab_name].sort(key=due_sort_key)

    return agenda


def render_board(
    board_name: str, tabs: dict[str, list[Card]], max_content: int, renderer: Renderer
) -> None:
    if not tabs:
        print(f"Board '{board_name}' has no tabs.")
        return

    rendered_tabs: list[tuple[str, list[Card], int]] = []
    for tab_name, tab_cards in tabs.items():
        visible_cards = [card for card in tab_cards if not card.archive]
        if not visible_cards:
            continue
        archived_count = len(tab_cards) - len(visible_cards)
        rendered_tabs.append((tab_name, visible_cards, archived_count))

    if not rendered_tabs:
        print(f"Board '{board_name}' has no cards.")
        return

    terminal_width = shutil.get_terminal_size(fallback=(120, 40)).columns
    gap = "   "
    min_col_width = 28
    max_columns = max(1, (terminal_width + len(gap)) // (min_col_width + len(gap)))

    for group in chunked(rendered_tabs, max_columns):
        columns = len(group)
        col_width = max(
            min_col_width,
            (terminal_width - (len(gap) * (columns - 1))) // max(columns, 1),
        )

        matrix: list[list[str]] = []
        for tab_name, visible_cards, archived_count in group:
            header = (
                tab_name if archived_count == 0 else f"{tab_name} ({archived_count})"
            )

            lines = [renderer.muted(header), renderer.muted("-" * col_width)]
            for card in visible_cards:
                lines.extend(build_card_lines(card, col_width, max_content, renderer))
            matrix.append(lines)

        max_rows = max(len(col) for col in matrix)
        for col in matrix:
            col.extend([""] * (max_rows - len(col)))

        for row in range(max_rows):
            row_text = gap.join(pad_visible(col[row], col_width) for col in matrix)
            print(row_text.rstrip())

        print()


def parse_args(argv: list[str] | None = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Render a filesystem-backed kanban board in the terminal."
    )
    parser.add_argument(
        "-b",
        "--board",
        help="Board name or partial board name (directory under KANBAN_HOME)",
    )
    parser.add_argument(
        "-l",
        dest="list_boards",
        action="store_true",
        help="List available boards and exit",
    )
    parser.add_argument(
        "-n", dest="no_color", action="store_true", help="Disable ANSI styling"
    )
    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv)

    home = default_kanban_home()
    color_enabled = (
        bool(sys.stdout.isatty())
        and not args.no_color
        and os.environ.get("NO_COLOR") is None
    )
    renderer = Renderer(enable_color=color_enabled)

    if args.list_boards:
        boards = list_boards(home)
        if not boards:
            print(f"No boards found in {home}")
            return 0
        for board in boards:
            print(board)
        return 0

    if not args.board:
        if not list_boards(home):
            print(f"No boards found in {home}")
            return 2
        try:
            render_board(
                "Agenda",
                build_due_agenda(home),
                max_content=DEFAULT_MAX_CONTENT,
                renderer=renderer,
            )
        except OSError as exc:
            print(f"Failed to read board data: {exc}", file=sys.stderr)
            return 1
        return 0

    try:
        board_name = resolve_board_name(home, args.board)
        _, board_data = load_board(home, board_name)
    except AmbiguousBoardMatchError as exc:
        print(str(exc), file=sys.stderr)
        return 1
    except FileNotFoundError as exc:
        print(str(exc), file=sys.stderr)
        boards = list_boards(home)
        if boards:
            print("Available boards:", file=sys.stderr)
            for board in boards:
                print(f"- {board}", file=sys.stderr)
        return 1
    except OSError as exc:
        print(f"Failed to read board data: {exc}", file=sys.stderr)
        return 1

    render_board(
        board_name, board_data, max_content=DEFAULT_MAX_CONTENT, renderer=renderer
    )
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
